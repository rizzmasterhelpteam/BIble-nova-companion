# GROQ_API_KEY: Server-only Groq key used by /api/chat.
GROQ_API_KEY="MY_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"

# GROK_API_KEY: Optional xAI Grok key for chat.
GROK_API_KEY="MY_GROK_API_KEY"
GROK_MODEL="grok-3-mini"

# GEMINI_API_KEY: Optional Google Gemini key used by /api/generate.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_SUPABASE_URL: Your Supabase Project URL
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase Anon Public Key
VITE_SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Server-only key required for account deletion, rate limits, and entitlements.
# Never expose this in client-side code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# RATE_LIMIT_IP_SALT: Server-only random value used to hash IP-based rate-limit keys.
RATE_LIMIT_IP_SALT="generate-a-long-random-value"

# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON: Server-only JSON credentials used to verify Android subscriptions.
# Grant the service account access to the Google Play Developer API for this app.
# Never expose this in client-side code.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON='{"client_email":"service-account@project.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}'

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Required for native mobile builds so Capacitor calls your Vercel backend.
# Leave empty for same-origin web deploys.
VITE_API_BASE_URL="https://biblecompanion.vercel.app"

# VITE_APP_VERSION: Optional web UI version label; defaults to the current release version.
VITE_APP_VERSION="1.1.4"

# Release builds use bundled assets from dist. Enable this only for local live reload.
CAPACITOR_LIVE_RELOAD="false"
CAPACITOR_SERVER_URL="http://localhost:5173"

# Native Google Sign-In client IDs.
# VITE_GOOGLE_WEB_CLIENT_ID is required for Android native Google sign-in and also works as the iOS server client ID fallback.
# VITE_GOOGLE_IOS_CLIENT_ID is required for iOS native Google sign-in.
# VITE_GOOGLE_IOS_SERVER_CLIENT_ID is optional; when omitted the app reuses VITE_GOOGLE_WEB_CLIENT_ID.
VITE_GOOGLE_WEB_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"
VITE_GOOGLE_IOS_CLIENT_ID="your-ios-client-id.apps.googleusercontent.com"
VITE_GOOGLE_IOS_SERVER_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"

# VITE_GOOGLE_PLAY_PUBLIC_KEY: Google Play monetization RSA public key.
# Public value used for Android billing / purchase-verification integrations when needed.
VITE_GOOGLE_PLAY_PUBLIC_KEY=""

# Native IAP product IDs for subscriptions.
# Use your App Store / Play Console product IDs.
VITE_IAP_MONTHLY_PRODUCT_ID="biblenova"
VITE_IAP_YEARLY_PRODUCT_ID="biblenovayearly"

# Android-only Google Play base plan IDs for the subscription products above.
VITE_IAP_MONTHLY_BASE_PLAN_ID="monthly"
VITE_IAP_YEARLY_BASE_PLAN_ID="yearlyoffer"
