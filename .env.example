# GROQ_API_KEY: Server-only Groq key used by /api/chat.
GROQ_API_KEY="MY_GROQ_API_KEY"
GROQ_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# GROK_API_KEY: Optional xAI Grok key for chat.
GROK_API_KEY="MY_GROK_API_KEY"

# GEMINI_API_KEY: Optional Google Gemini key used by /api/generate.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_SUPABASE_URL: Your Supabase Project URL
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase Anon Public Key
VITE_SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Server-only key required for signed-in account deletion.
# Never expose this in client-side code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
